@model IEnumerable<UserViewModel>
@inject UserManager<ApplicationUser> _userManager ;
@{
    ViewData["Title"] = "Users";
}

@section Styles {
    <link href="~/assets/plugins/datatables/datatables.bundle.css" rel="stylesheet" />
}


<div class="alert bg-light-primary border border-primary border-3 border-dashed d-flex justify-content-between flex-sm-row w-100 p-5 mb-10 align-items-center ">
    <div class="d-flex align-items-center">
        <!--begin::Icon-->
        <span class="svg-icon svg-icon-1 mx-3 ">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" class="bi bi-bag-heart-fill" viewBox="0 0 16 16">
                <path d="M11.5 4v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4zM8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1m0 6.993c1.664-1.711 5.825 1.283 0 5.132-5.825-3.85-1.664-6.843 0-5.132"></path>
            </svg>
        </span>    <!--begin::Content-->
        <div class="d-flex flex-column pe-0 pe-sm-10 align-items-center">
            <h5 class="m-0">Users</h5>
        </div>
        <!--end::Content-->
    </div>
    <div>
        <a class="btn btn-primary hover-scale me-3" asp-action="Create">
            <span class="indicator-label">
                Add
            </span>
            <span class="indicator-progress">
                please wait...<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
            </span>
        </a>
    </div>
</div>



<div class="card shadow-sm">
    <partial name="_DataTablesCardHeader" />
    <div class="card-body pt-0">

        <div class="table-responsive">
            <table class="table table-row-dashed table-row-gray-300 gy-2 align-middle js-datatable" data-document-title="Users Report">
                <thead>
                    <tr class="text-start text-gray-500 fw-bold fs-7 text-uppercase">
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>National Id</th>

                        <th>Blood Type</th>

                        <th class="js-no-export ">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td>
                                <div class="alert alert-info d-flex align-items-center p-5 ">
                                    <i class="ki-duotone ki-shield-tick fs-2hx text-info me-4">
                                        <span class="path1"></span><span class="path2"></span>
                                    </i>
                                    <div class="d-flex flex-column">
                                        <h4 class="mb-1 text-info">There are no Users available.</h4>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.NationalId</td>
                                <td>@item.BloodType</td>
                              
                                <td>
                                    <a class="btn btn-sm btn-light-primary hover-scale me-3" asp-action="Edit" asp-route-Id="@item.Id">
                                        <span class="indicator-label">
                                            Edit
                                        </span>
                                        <span class="indicator-progress">
                                            please wait...<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                        </span>
                                    </a>

                                    <a class="btn btn-sm btn-light-warning hover-scale me-3" asp-action="ResetPassword" asp-route-Id="@item.Id">
                                        <span class="indicator-label">
                                            Reset Password
                                        </span>
                                        <span class="indicator-progress">
                                            please wait...<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                        </span>
                                    </a>

                                    @if (!(bool)ViewBag.UserRoles[item.Id])
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline ">
                                            <button type="submit" class="btn btn-sm btn-light-danger hover-scale me-3"
                                                    onclick="return confirm('Are you sure you want to delete this user?');">
                                                <span class="indicator-label">
                                                    Delete
                                                </span>
                                                <span class="indicator-progress">
                                                    please wait...<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                                </span>
                                            </button>
                                        </form>
                                    }
                                 

                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>

    </div>
</div>







@section Plugins {
    <script src="~/assets/plugins/datatables/datatables.bundle.js"></script>
}