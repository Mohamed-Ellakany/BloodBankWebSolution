{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB; Database=BloodBank; TrustServerCertificate=True; MultipleActiveResultSets=True;",
    "HangfireConnection": "Server=(localdb)\\MSSQLLocalDB; Database=BloodBankJobs; TrustServerCertificate=True; MultipleActiveResultSets=True;"

  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information",
      "BloodBank.Api.Controllers": "Error"

    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": "Error",
    "Override": {
      "Microsoft": "Error"
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=(localdb)\\MSSQLLocalDB; Database=BloodBank; TrustServerCertificate=True; MultipleActiveResultSets=True;",
          "tableName": "ErrorLogs",
          "schemaName": "Logging",
          "autoCreateSqlTable": true

        },
        "restrictedToMinimumLevel": "Error"
      }
    ],
    "Properties": {
      "ApplicationName": "BloodBank.Api"
    }
  }

}
